# Copy to .env and fill with your Supabase project values.
# Required for the built app (moneymachine.exe) to use your real account and data.
# Without these, the app runs in "mock" mode with default/placeholder data.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
